{
  "name": "sdd-navigator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "lint": "eslint",
    "test": "jest",
    "check-coverage": "node scripts/check-coverage.ts",
    "check-dry": "node scripts/check-dry.ts",
    "check:sdd": "npm run check-coverage && npm run check-dry",
    "report:sdd": "npm run check:sdd && node scripts/generate-sdd-report.ts",
    "prepush": "npm run report:sdd && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "20.19.37",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "js-yaml": "^4.1.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
